    <script>
      $(function() {
        $(".gnb_menu_btn").click(function() {
          $("#gnb_all_bg").removeClass("hidden");
          $("#gnb_all").removeClass("-left-74").addClass("left-0");
        });
        $(".gnb_close_btn, #gnb_all_bg").click(function() {
          $("#gnb_all").removeClass("left-0").addClass("-left-74");
          $("#gnb_all_bg").addClass("hidden");
        });
      });

      document.querySelectorAll('.gnb_al_a').forEach(item => {
        const siblingUl = item.nextElementSibling;
        const svgIcon = item.querySelector('svg');

        // 형제 ul이 없을 경우
        if (!siblingUl || siblingUl.tagName !== 'UL') {
          if (svgIcon) {
            svgIcon.classList.add('hidden'); // svg 숨김
          }
          return; // 클릭 이벤트 등록하지 않음
        }

        // 형제 ul이 존재할 경우 링크 제거
        item.removeAttribute('href');
        item.style.cursor = 'pointer';

        // 초기 상태 설정
        siblingUl.classList.add('max-h-0', 'overflow-hidden', 'transition-[max-height]', 'duration-500');

        // 클릭 이벤트 등록
        item.addEventListener('click', () => {
          const isOpen = siblingUl.classList.contains('max-h-[500px]');

          // 토글 처리
          siblingUl.classList.toggle('max-h-0', isOpen);
          siblingUl.classList.toggle('max-h-[500px]', !isOpen); // 원하는 최대 높이

          // rotate-180 처리
          if (svgIcon) {
            svgIcon.classList.toggle('rotate-180', !isOpen);
          }
        });
      });
    </script>

