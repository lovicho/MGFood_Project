                <div class="flex items-center text-sm">
                    <input type="checkbox" id="agree_privacy" name="agree_privacy" value="1" class="w-4 h-4 mr-2 accent-white cursor-pointer">
                    <label for="agree_privacy" class="cursor-pointer select-none">
                        개인정보처리방침 동의
                    </label>
                    <a href="https://a-onefood.kr/bbs/content.php?co_id=privacy" target="_blank" class="ml-1 underline text-xs opacity-80 hover:opacity-100">[보기]</a>
                </div>

                <button type="submit" class="border border-white text-white px-6 py-2 h-10 text-sm hover:bg-white hover:text-[#ff554f] transition font-bold">
