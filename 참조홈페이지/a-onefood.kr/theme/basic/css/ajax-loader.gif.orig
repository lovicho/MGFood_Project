                <input type="text" name="wr_name" required class="bg-transparent border border-white text-white placeholder-white px-3 py-2 outline-none w-full md:w-32 h-10 text-sm focus:bg-white/10 transition" placeholder="이름">

                <input type="text" name="wr_content" required class="bg-transparent border border-white text-white placeholder-white px-3 py-2 outline-none w-full md:w-40 h-10 text-sm focus:bg-white/10 transition" placeholder="연락처">
            </div>

