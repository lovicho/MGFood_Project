                        개인정보처리방침 동의
                    </label>
                    <a href="https://a-onefood.kr/bbs/content.php?co_id=privacy" target="_blank" class="ml-1 underline text-xs opacity-80 hover:opacity-100">[보기]</a>
                </div>

                <button type="submit" class="border border-white text-white px-6 py-2 h-10 text-sm hover:bg-white hover:text-[#ff554f] transition font-bold">
                    상담신청하기
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .quick {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        z-index: 9;
    }

    .quick-relative {
        position: relative;
    }
</style>

<script>
    document.addEventListener("scroll", function() {
        var footer = document.querySelector("#ft");
        // footer가 없는 페이지에서의 오류 방지
        if(!footer) return; 

        var footerRect = footer.getBoundingClientRect();
        var footerTop = footerRect.top;
        var windowHeight = window.innerHeight;

        var footerQuickTest = document.querySelector("#quickConsultWrap");

        if (footerTop < windowHeight) {
            footerQuickTest.classList.add("quick-relative");
        } else {
            footerQuickTest.classList.remove("quick-relative");
        }
    });

    function fquickconsult_submit(f) {
        // 1. 유효성 검사 (이름)
        if (!f.wr_name.value) {
            alert("이름을 입력해 주세요.");
            f.wr_name.focus();
            return false;
        }
        // 2. 유효성 검사 (연락처)
        if (!f.wr_content.value) {
            alert("연락처를 입력해 주세요.");
            f.wr_content.focus();
            return false;
        }
        // 3. 개인정보 동의 검사
        if (!f.agree_privacy.checked) {
            alert("개인정보처리방침에 동의해 주세요.");
            f.agree_privacy.focus();
            return false;
        }

        // 입력한 이름 가져오기
        var inputName = f.wr_name.value;

        // 4. AJAX(비동기) 전송 처리
        var formData = new FormData(f);

        fetch(f.action, {
            method: 'POST',
            body: formData
        })
        .then(function(response) {
            // 전송 성공 시 실행
            // 요청하신 문구 출력
            alert(inputName + "님 상담신청이 완료되었습니다.");
            
            // 폼 초기화 (선택사항: 완료 후 내용 지우기)
            f.reset(); 
        })
        .catch(function(error) {
            // 에러 발생 시
            console.error('Error:', error);
            alert("접수 중 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.");
        });

        // 5. 기본 폼 제출 동작(페이지 이동/새로고침) 막기
        return false;
    }
</script><style>
  #quickConsultWrap {
    display: block;
  }
</style>
